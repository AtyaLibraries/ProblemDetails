<Project Sdk="Atya.Build.Sdk">

  <PropertyGroup>
    <PackageId>Atya.Errors.ProblemDetails</PackageId>
    <AssemblyName>Atya.Errors.ProblemDetails</AssemblyName>
    <RootNamespace>Atya.Errors.ProblemDetails</RootNamespace>
    <IsPackable>true</IsPackable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <PackageValidationBaselineVersion>1.0.0</PackageValidationBaselineVersion>
    <Authors>Arsen Asulyan</Authors>
    <Company>Atya</Company>
    <Copyright>Copyright (c) 2026 Arsen Asulyan</Copyright>
    <Description>Problem Details helpers for ASP.NET Core Atya services.</Description>
    <PackageTags>dotnet;errors;problem-details;aspnetcore;atya</PackageTags>
    <RepositoryUrl>https://github.com/AtyaLibraries/ProblemDetails</RepositoryUrl>
    <PackageProjectUrl>$(RepositoryUrl)</PackageProjectUrl>

    <!-- MinVer derives the version from git tags (e.g. tag `v1.2.3` -> 1.2.3). -->
    <MinVerTagPrefix>v</MinVerTagPrefix>
    <MinVerDefaultPreReleaseIdentifiers>alpha.0</MinVerDefaultPreReleaseIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

  <ItemGroup Label="Runtime dependencies">
    <PackageReference Include="Atya.Errors.Exceptions" />
    <PackageReference Include="Atya.Foundation.Guards" />
    <PackageReference Include="Atya.Foundation.Results" />
  </ItemGroup>

</Project>

